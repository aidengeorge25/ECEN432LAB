import numpy as np
import matplotlib.pyplot as plt
from scipy.fft import fft, ifft, fftfreq

def metrics(vout):
    vout_ac = vout - np.mean(vout)

    #Windowing reduces spectral leakage
    window = np.hanning(N)
    vout_w = vout_ac * window

    # FFT
    V = np.fft.fft(vout_ac)
    freq = np.fft.fftfreq(N, d=1/fs)

    # Keep only positive frequencies
    half = N // 2
    V = V[:half]
    freq = freq[:half]

    # PSD (proper scaling)
    psd = (np.abs(V)**2) / N
    mag2 = 2*np.abs(V)**2 /N

    # Find fundamental bin
    fund_bin = np.argmax(mag2)

    # Signal power = fundamental bin only
    signal_power = psd[fund_bin]
    noise_power = (np.sum(psd)-signal_power)
    sndr = 10 * np.log10(signal_power / noise_power)
    enob = (sndr - 1.76)/6.02
    return sndr, enob


