import numpy as np
import matplotlib.pyplot as plt

class FlashADC:
    def __init__(self, n_bits, vfs):
        self.n_bits = n_bits
        self.vfs = vfs
        
        # Number of comparators
        self.num_comparators = 2**n_bits - 1
        
        # Step size
        self.delta = vfs / (2**n_bits)
        
        # Reference levels
        self.references = np.array([i * self.delta for i in range(1, 2**n_bits)])
    
    def quantize(self, vin):
        """
        Returns thermometer code and binary output
        """
        # Comparator outputs (thermometer code)
        thermometer = (vin >= self.references).astype(int)
        level = np.sum(thermometer)
        return level
        
    def generate_nonideal_refs(self):
        """
        Adds:
        - offset
        - gain error
        - 2nd and 3rd order nonlinearity
        """
        refs = self.ideal_refs.copy()
        
        # Random error parameters per comparator
        offset = np.random.normal(0, 0.01, size=refs.shape)
        gain = np.random.normal(0, 0.02, size=refs.shape)
        a2 = np.random.normal(0, 0.005, size=refs.shape)
        a3 = np.random.normal(0, 0.002, size=refs.shape)
        
        # Apply distortion
        refs = refs * (1 + gain)
        refs = refs + offset
        refs = refs + a2 * refs**2 + a3 * refs**3
        
        # Ensure monotonic ordering (important for flash ADC)
        refs = np.sort(refs)
        
        return refs 
    def to_binary(self, level):
        return format(level, f'0{self.n_bits}b')

