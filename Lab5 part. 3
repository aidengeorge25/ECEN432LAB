import numpy as np
import matplotlib.pyplot as plt

# Full-scale
VFS = 1.0

# Sweep input

# Ideal gain
G = 4
def gain(Vin,G,Vref):
    offset = .3
    e = 0.05
    a2 = 0.02
    a3 = 0.01
    print(a2)
    Vout=(1+e)*G*Vin+a2*Vin**2+a3*Vin**3+offset
    return Vout


# Signal parameters
fs = 1e6
N = 2**12
t = np.arange(N) / fs

fin = fs * 7459 / N   # coherent tone
A = .49 * VFS

# Input signal
Vin = A * np.sin(2*np.pi*fin*t)+.5

# Ideal output
Vout = gain(Vin,4,1)

# FFT
spectrum = np.fft.fft(Vout)
spectrum = np.abs(spectrum[:N // 2])  # single-sided spectrum
freq = np.fft.fftfreq(N, 1/fs)
# Power spectrum
power = spectrum ** 2
half = N//2
PSD = PSD[:half]
freq = freq[:half]
# Find fundamental frequency bin (ignore DC at index 0)
fundamental_bin = np.argmax(power[1:]) +1

# Signal power (fundamental bin)
signal_power = power[fundamental_bin]

# Noise + distortion power (exclude DC and fundamental)
noise_distortion_power = np.sum(power[1:N]) - signal_power

# SNDR
sndr = signal_power / noise_distortion_power
SNDR = 10 * np.log10(sndr)
ENOB=((SNDR - 1.76) / 6.02)

print("Ideal SNDR:", SNDR)
print("Ideal ENOB:", ENOB)

plt.figure()
plt.plot(t[0:50],Vout[0:50])
plt.title("Amplifier Output")
plt.xlabel("Vin")
plt.ylabel("Vout")
plt.grid()
plt.show()
# Plot PSD
plt.figure()
plt.plot(freq, 10*np.log10(power))
plt.title("PSD (Ideal)")
plt.xlabel("Frequency")
plt.ylabel("dB")
plt.grid()
plt.show()

